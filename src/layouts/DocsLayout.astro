---
// DocsLayout.astro
// Three-column documentation layout: Sidebar | Content | TOC Rail

import TopBar from '../components/TopBar.astro';
import Sidebar from '../components/Sidebar.astro';
import OnPageTOC from '../components/OnPageTOC.astro';
import { ViewTransitions } from 'astro:transitions';
import '../styles/global.css';

interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  title: string;
  description?: string;
  headings?: Heading[];
}

// MDX pages pass frontmatter via Astro.props.frontmatter; .astro pages pass directly
const fm = (Astro.props as any).frontmatter ?? Astro.props;
const {
  title,
  description = 'TokenNexus documentation - connect GitHub design tokens to Figma variables.',
} = fm;
const headings = (Astro.props as any).headings ?? fm.headings ?? [];

const siteName = 'TokenNexus';
const fullTitle = title === siteName ? siteName : `${title} - ${siteName}`;
const canonicalURL = new URL(Astro.url.pathname, Astro.site ?? 'https://ojanti.github.io');
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />

    <!-- Canonical -->
    <link rel="canonical" href={canonicalURL.toString()} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL.toString()} />
    <meta property="og:site_name" content={siteName} />

    <!-- Twitter/X Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />

    <!-- Favicon (inline SVG via data URI - curly braces logo) -->
    <link
      rel="icon"
      type="image/svg+xml"
      href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 32 32'%3E%3Cdefs%3E%3ClinearGradient id='g' x1='0' y1='0' x2='32' y2='0' gradientUnits='userSpaceOnUse'%3E%3Cstop offset='0%25' stop-color='%235B8EF5'/%3E%3Cstop offset='50%25' stop-color='%238B6BF5'/%3E%3Cstop offset='100%25' stop-color='%23F572B6'/%3E%3C/linearGradient%3E%3C/defs%3E%3Cpath d='M13 4C10 4 9 5 9 8L9 10C9 12 8 13 6 14C8 15 9 16 9 18L9 20C9 23 10 24 13 24' stroke='%238A90B4' stroke-width='2' stroke-linecap='round' fill='none'/%3E%3Cpath d='M19 4C22 4 23 5 23 8L23 10C23 12 24 13 26 14C24 15 23 16 23 18L23 20C23 23 22 24 19 24' stroke='%238A90B4' stroke-width='2' stroke-linecap='round' fill='none'/%3E%3Cline x1='4' y1='16' x2='28' y2='16' stroke='url(%23g)' stroke-width='2' stroke-linecap='round'/%3E%3C/svg%3E"
    />

    <!-- Google Fonts: Geist, Geist Mono, Inter -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Geist:wght@400;500;600;700;800&family=Geist+Mono:wght@400;500&family=Inter:wght@400;500;600&display=swap"
      rel="stylesheet"
    />


    <title>{fullTitle}</title>
    <ViewTransitions fallback="none" />
  </head>

  <body>
    <TopBar />

    <div class="shell">
      <div class="layout">
        <Sidebar currentPath={Astro.url.pathname} />

        <main class="content" id="main-content">
          <div class="content-inner" data-pagefind-body>
            <slot />
          </div>
          <aside class="toc-rail" aria-label="On this page">
            <OnPageTOC />
          </aside>
        </main>
      </div>
    </div>

    <script>
      function initHeadingAnchors() {
        document.querySelectorAll<HTMLElement>('.content-inner h2, .content-inner h3').forEach((heading) => {
          if (!heading.id || heading.querySelector('.heading-anchor-btn')) return;
          const btn = document.createElement('button');
          btn.className = 'heading-anchor-btn';
          btn.setAttribute('aria-label', 'Copy link to section');
          btn.innerHTML = `<svg width="14" height="14" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M6.5 9.5a3.5 3.5 0 004.95 0l2-2a3.5 3.5 0 00-4.95-4.95l-1.25 1.25" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/><path d="M9.5 6.5a3.5 3.5 0 00-4.95 0l-2 2a3.5 3.5 0 004.95 4.95l1.25-1.25" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>`;

          const tooltip = document.createElement('span');
          tooltip.className = 'heading-anchor-tooltip';
          tooltip.textContent = 'Link copied';
          btn.appendChild(tooltip);

          btn.addEventListener('click', () => {
            const url = `${window.location.origin}${window.location.pathname}#${heading.id}`;
            navigator.clipboard.writeText(url).then(() => {
              tooltip.classList.add('heading-anchor-tooltip--visible');
              setTimeout(() => tooltip.classList.remove('heading-anchor-tooltip--visible'), 1800);
            });
          });

          heading.appendChild(btn);
        });
      }

      function initExternalLinks() {
        document.querySelectorAll<HTMLAnchorElement>('.content-inner a[href]').forEach((a) => {
          if (a.hostname && a.hostname !== window.location.hostname) {
            a.setAttribute('target', '_blank');
            a.setAttribute('rel', 'noopener noreferrer');
          }
        });
      }

      initHeadingAnchors();
      initExternalLinks();
      document.addEventListener('astro:page-load', () => {
        initHeadingAnchors();
        initExternalLinks();
      });
    </script>
  </body>
</html>
