---
interface Props {
  label: string;
  src?: string;
  alt?: string;
  ratio?: string;
  height?: number;
  caption?: string;
}

const { label, src, alt, ratio = '16/9', height, caption } = Astro.props;

const withBase = (value?: string) => {
  if (!value) {
    return undefined;
  }
  if (/^(https?:)?\/\//.test(value) || value.startsWith('data:')) {
    return value;
  }

  const base = import.meta.env.BASE_URL.replace(/\/$/, '');
  const normalizedValue = value.replace(/^\/token-nexus-docs/, '').replace(/^\/+/, '/');
  return `${base}${normalizedValue}`;
};

const placeholderStyle = height
  ? `height: ${height}px; aspect-ratio: unset;`
  : `aspect-ratio: ${ratio};`;

const resolvedAlt = alt ?? label;

const resolvedSrc = withBase(src);
---

{resolvedSrc ? (
  <figure class="doc-image">
    <img src={resolvedSrc} alt={resolvedAlt} loading="lazy" />
    {caption && <figcaption>{caption}</figcaption>}
  </figure>
) : (
  <div
    class="img-placeholder"
    style={placeholderStyle}
    aria-label={label}
    role="img"
  >
    <span>{label}</span>
  </div>
)}

<style>
  .doc-image {
    margin: 1.5rem 0;
    background: var(--bg-surface-1);
    border: 1px solid var(--border-subtle);
    border-radius: 8px;
    overflow: hidden;
  }

  .doc-image img {
    width: 100%;
    height: auto;
    display: block;
  }

  .doc-image figcaption {
    display: block;
    font-size: 12px;
    font-style: italic;
    color: var(--text-muted);
    padding: 8px 12px;
    border-top: 1px solid var(--border-subtle);
  }
</style>
