---
// OnPageTOC.astro
// DOM-based TOC - scans content-inner at runtime so component headings are included
---

<div class="toc-rail-inner" id="toc-rail-inner" style="display:none">
  <span class="toc-label">On this page</span>
  <ul class="toc-list" id="toc-list"></ul>
</div>

<script>
  function initTOC() {
    const container = document.getElementById('toc-rail-inner');
    const list = document.getElementById('toc-list');
    if (!container || !list) return;

    const headingEls = Array.from(
      document.querySelectorAll<HTMLElement>('.content-inner h2, .content-inner h3')
    ).filter((el) => el.id);

    list.innerHTML = '';

    if (headingEls.length < 2) {
      container.style.display = 'none';
      return;
    }

    headingEls.forEach((el) => {
      const depth = parseInt(el.tagName[1]);
      // Clone to strip anchor button before reading text
      const cloned = el.cloneNode(true) as HTMLElement;
      cloned.querySelector('.heading-anchor-btn')?.remove();
      const text = cloned.textContent?.trim() ?? '';

      const li = document.createElement('li');
      li.className = `toc-item toc-item--h${depth}`;
      const a = document.createElement('a');
      a.href = `#${el.id}`;
      a.className = depth === 3 ? 'toc-link toc-link-h3' : 'toc-link';
      a.dataset.tocTarget = el.id;
      a.textContent = text;
      li.appendChild(a);
      list.appendChild(li);
    });

    container.style.display = '';

    const tocLinks = list.querySelectorAll<HTMLAnchorElement>('[data-toc-target]');
    let activeId: string | null = null;

    function setActive(id: string | null) {
      if (id === activeId) return;
      activeId = id;
      tocLinks.forEach((link) => {
        link.classList.toggle('active', link.dataset.tocTarget === id);
      });
    }

    const observer = new IntersectionObserver(
      (entries) => {
        const visible = entries
          .filter((e) => e.isIntersecting)
          .sort((a, b) => a.boundingClientRect.top - b.boundingClientRect.top);
        if (visible.length > 0) setActive(visible[0].target.id);
      },
      { rootMargin: '-64px 0px -70% 0px', threshold: 0 }
    );

    headingEls.forEach((el) => observer.observe(el));
    if (headingEls[0]?.id) setActive(headingEls[0].id);
  }

  initTOC();
  document.addEventListener('astro:page-load', initTOC);
</script>
