---
// TopBar.astro
// Sticky 56px navigation bar with beam gradient underline
---

<header class="topbar">
  <div class="topbar-inner">
    <a href="/token-nexus-docs/" class="topbar-left" aria-label="TokenNexus home">
      <!-- Logo: curly braces with beam gradient beam through center -->
      <svg width="28" height="28" viewBox="0 0 28 28" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
        <defs>
          <linearGradient id="logo-beam" x1="0" y1="0" x2="28" y2="0" gradientUnits="userSpaceOnUse">
            <stop offset="0%" stop-color="#5B8EF5" />
            <stop offset="50%" stop-color="#8B6BF5" />
            <stop offset="100%" stop-color="#F572B6" />
          </linearGradient>
        </defs>
        <!-- Left brace -->
        <path
          d="M11 4 C8 4 7 5 7 8 L7 10 C7 12 6 13 4 14 C6 15 7 16 7 18 L7 20 C7 23 8 24 11 24"
          stroke="#8A90B4"
          stroke-width="1.5"
          stroke-linecap="round"
          stroke-linejoin="round"
          fill="none"
        />
        <!-- Right brace -->
        <path
          d="M17 4 C20 4 21 5 21 8 L21 10 C21 12 22 13 24 14 C22 15 21 16 21 18 L21 20 C21 23 20 24 17 24"
          stroke="#8A90B4"
          stroke-width="1.5"
          stroke-linecap="round"
          stroke-linejoin="round"
          fill="none"
        />
        <!-- Beam gradient line through center -->
        <line x1="3" y1="14" x2="25" y2="14" stroke="url(#logo-beam)" stroke-width="1.5" stroke-linecap="round" />
      </svg>
      <span class="topbar-wordmark">TokenNexus</span>
    </a>

    <div class="topbar-right">
      <a
        href="https://www.figma.com/community/plugin/1617061240636708738/tokennexus-for-figma"
        target="_blank"
        rel="noopener noreferrer"
        class="topbar-cta"
      >
        <svg width="13" height="13" viewBox="0 0 24 24" fill="white" aria-hidden="true" style="flex-shrink:0" xmlns="http://www.w3.org/2000/svg"><path d="M15.852 8.981h-4.588V0h4.588c2.476 0 4.49 2.014 4.49 4.49s-2.014 4.491-4.49 4.491zM12.735 7.51h3.117c1.665 0 3.019-1.355 3.019-3.019s-1.355-3.019-3.019-3.019h-3.117V7.51zm0 1.471H8.148c-2.476 0-4.49-2.014-4.49-4.49S5.672 0 8.148 0h4.588v8.981zm-4.587-7.51c-1.665 0-3.019 1.355-3.019 3.019s1.354 3.02 3.019 3.02h3.117V1.471H8.148zm4.587 15.019H8.148c-2.476 0-4.49-2.014-4.49-4.49s2.014-4.49 4.49-4.49h4.588v8.98zM8.148 8.981c-1.665 0-3.019 1.355-3.019 3.019s1.355 3.019 3.019 3.019h3.117V8.981H8.148zM8.172 24c-2.489 0-4.515-2.014-4.515-4.49s2.014-4.49 4.49-4.49h4.588v4.441c0 2.503-2.047 4.539-4.563 4.539zm-.024-7.51a3.023 3.023 0 0 0-3.019 3.019c0 1.665 1.365 3.019 3.044 3.019 1.705 0 3.093-1.376 3.093-3.068v-2.97H8.148zm7.704 0h-.098c-2.476 0-4.49-2.014-4.49-4.49s2.014-4.49 4.49-4.49h.098c2.476 0 4.49 2.014 4.49 4.49s-2.014 4.49-4.49 4.49zm-.097-7.509c-1.665 0-3.019 1.355-3.019 3.019s1.355 3.019 3.019 3.019h.098c1.665 0 3.019-1.355 3.019-3.019s-1.355-3.019-3.019-3.019h-.098z"/></svg>
        Install Plugin
      </a>

      <!-- Mobile hamburger -->
      <button
        class="topbar-hamburger"
        id="sidebar-toggle"
        aria-label="Toggle navigation"
        aria-expanded="false"
        aria-controls="sidebar"
      >
        <svg width="20" height="20" viewBox="0 0 20 20" fill="currentColor" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <rect y="3" width="20" height="2" rx="1" />
          <rect y="9" width="20" height="2" rx="1" />
          <rect y="15" width="20" height="2" rx="1" />
        </svg>
      </button>
    </div>
  </div>
</header>

<!-- Mobile sidebar JS handled in Sidebar.astro -->
